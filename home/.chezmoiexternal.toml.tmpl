# chezmoi externals: only things Homebrew doesn't manage (the zsh plugin
# manager, tinty's scheme data, bat's syntax def, fonts). CLI tool *binaries*
# are installed via Homebrew on macOS (see .chezmoiscripts/...install-packages).

# Antidote - the ZSH plugin manager (cloned into $ZDOTDIR/.antidote).
[".config/zsh/.antidote"]
    type = "git-repo"
    url = "https://github.com/mattmc3/antidote.git"
    refreshPeriod = "168h"

# tinty - base16/base24 theme manager. Not in brew core (only an untrusted tap),
# so kept as a direct-binary external (macOS). The brew-on-macOS exception.
[".local/bin/tinty"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "tinted-theming/tinty" (printf "tinty-%s-apple-darwin.tar.gz" .appleArch) | quote }}
    path = "tinty"
    executable = true
    refreshPeriod = "168h"

# tinty's template + scheme repos, pre-cloned into its data dir so it needs no
# `tinty install` step and they auto-update.
[".local/share/tinted-theming/tinty/repos/tinted-shell"]
    type = "git-repo"
    url = "https://github.com/tinted-theming/tinted-shell.git"
    refreshPeriod = "168h"
    clone.args = ["--depth=1"]
    pull.args = ["--ff-only"]

[".local/share/tinted-theming/tinty/repos/schemes"]
    type = "git-repo"
    url = "https://github.com/tinted-theming/schemes.git"
    refreshPeriod = "168h"
    clone.args = ["--depth=1"]
    pull.args = ["--ff-only"]

# antidote's bat syntax for highlighting .zsh_plugins.txt files.
# Picked up after `bat cache --build` (run by .chezmoiscripts/...bat-cache).
[".config/bat/syntaxes/zsh_plugins.sublime-syntax"]
    type = "file"
    url = "https://github.com/getantidote/antidote/raw/main/misc/zsh_plugins.sublime-syntax"
    refreshPeriod = "720h"

# JetBrainsMono Nerd Font (Mono variant: single-width glyphs for terminals).
# Individual .ttf files pulled directly, so no 128MB family-zip download.
{{- $fontBase := "https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/JetBrainsMono/Ligatures" }}
{{- range (list "Regular" "Bold" "Italic" "BoldItalic") }}
["{{ $.fontDir }}/JetBrainsMonoNerdFontMono-{{ . }}.ttf"]
    type = "file"
    url = "{{ $fontBase }}/{{ . }}/JetBrainsMonoNerdFontMono-{{ . }}.ttf"
    refreshPeriod = "8760h"
{{- end }}
