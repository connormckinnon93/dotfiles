#!/bin/bash
#
# Install Homebrew packages. Re-runs whenever the rendered package list below
# changes. The NN prefix (10-) fixes run order so later setup scripts can be
# sequenced deterministically (20-, 30-, ...) as this grows.
#
set -eufo pipefail

{{ $brews := list
      "atuin"
      "awscli"
      "bat"
      "borders"
      "carapace"
      "eza"
      "fd"
      "ffmpeg"
      "fzf"
      "gh"
      "ghostscript"
      "git-delta"
      "granted"
      "htop"
      "imagemagick"
      "jq"
      "lazygit"
      "mise"
      "neovim"
      "poppler"
      "resvg"
      "ripgrep"
      "sevenzip"
      "starship"
      "tectonic"
      "yazi"
      "yq"
      "zellij"
      "zoxide" -}}
{{- $casks := list
      "1password"
      "1password-cli"
      "aerospace"
      "ghostty" -}}
{{- /* Taps required by the casks above (e.g. aerospace lives in a tap). */ -}}
{{- $taps := list
      "FelixKratz/formulae"
      "nikitabobko/tap" -}}
{{- /* Profile-specific packages, merged into the base lists above as the
       personal and work machines diverge. .profile is "personal" or "work";
       replace (list) with e.g. (list "package-name") to add packages. */ -}}
{{- if eq .profile "personal" -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{- else if eq .profile "work" -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{- end -}}
{{- /* Stable-only packages, skipped on ephemeral machines (VMs/containers/CI) —
       e.g. GUI casks that make no sense on a headless throwaway box. */ -}}
{{- if not .ephemeral -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{- end -}}
{{- /* Ephemeral-only extras (rare; e.g. a CI-specific tool). */ -}}
{{- if .ephemeral -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{- end -}}

# Ensure brew is on PATH (e.g. immediately after a fresh install in this run,
# before the shell that adds it has been started).
{{ template "brew-shellenv" "brew" }}

# Third-party taps must be tapped and trusted before brew will load their
# casks/formulae (HOMEBREW_REQUIRE_TAP_TRUST). Do this before bundling.
{{ range ($taps | sortAlpha | uniq) -}}
brew tap "{{ . }}" >/dev/null 2>&1 || true
brew trust "{{ . }}" >/dev/null 2>&1 || true
{{ end }}
brew bundle --file=/dev/stdin <<EOF
{{ range ($taps | sortAlpha | uniq) -}}
tap "{{ . }}"
{{ end -}}
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF
