#!/bin/bash
#
# Install Homebrew packages. Re-runs whenever the rendered package list below
# changes. The NN prefix (10-) fixes run order so later setup scripts can be
# sequenced deterministically (20-, 30-, ...) as this grows.
#
set -eufo pipefail

{{ $brews := list
      "age"
      "atuin"
      "awscli"
      "bat"
      "btop"
      "carapace"
      "chezmoi"
      "duf"
      "eza"
      "fd"
      "fzf"
      "gdu"
      "gh"
      "ghostscript"
      "git"
      "git-delta"
      "git-lfs"
      "imagemagick"
      "jless"
      "jq"
      "lazygit"
      "mise"
      "neovim"
      "prek"
      "ripgrep"
      "shellcheck"
      "shfmt"
      "starship"
      "tectonic"
      "tree-sitter-cli"
      "yq"
      "zellij"
      "zoxide" -}}
{{- /* Base casks: universal, headless-safe, profile-neutral casks only. GUI
       apps live in the not-headless block below; personal-account apps live in
       the personal block. */ -}}
{{- $casks := list -}}
{{- /* Taps start empty and accumulate per-perspective below; the aerospace and
       borders taps are only needed on headed machines (not-headless block). */ -}}
{{- $taps := list -}}
{{- /* Profile-specific packages. .profile is "personal" or "work".

       Boundary guarantee (see CLAUDE.md): profile=work renders with NO
       personal accounts — anything tied to the owner's 1Password, tailnet,
       or personal app accounts belongs in the personal block, not the
       shared blocks below. */ -}}
{{- if eq .profile "personal" -}}
{{- /* granted/assume (AWS SSO helper) is personal-only; awscli stays in base.
       1password-cli is headless-safe and needed wherever templates
       onepasswordRead. */ -}}
{{-   $brews = concat $brews (list "granted") -}}
{{-   $casks = concat $casks (list "1password-cli") -}}
{{- /* Personal GUI apps (need a display too): gaming, plus every app that
       signs into a personal account — 1Password, Claude, Obsidian, the
       personal tailnet — and docker-desktop (needs a paid license at most
       employers, so it must not auto-install on a work machine). */ -}}
{{-   if not .headless -}}
{{-     $casks = concat $casks (list
            "1password"
            "balenaetcher"
            "brave-browser"
            "claude"
            "claude-code@latest"
            "docker-desktop"
            "epic-games"
            "obsidian"
            "steam"
            "tailscale-app") -}}
{{-   end -}}
{{- /* Personal headless boxes join the personal tailnet via the CLI/daemon. */ -}}
{{-   if .headless -}}
{{-     $brews = concat $brews (list "tailscale") -}}
{{-   end -}}
{{- else if eq .profile "work" -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{-   $taps = concat $taps (list) -}}
{{- end -}}
{{- /* Stable-only packages, skipped on ephemeral machines (VMs/containers/CI). */ -}}
{{- if not .ephemeral -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{-   $taps = concat $taps (list) -}}
{{- end -}}
{{- /* Ephemeral-only extras (rare; e.g. a CI-specific tool). */ -}}
{{- if .ephemeral -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{-   $taps = concat $taps (list) -}}
{{- end -}}
{{- /* GUI packages, skipped on headless machines (no display): profile-neutral
       GUI casks and their taps, plus GUI-only brews. CLI tools stay in the
       base list; personal-account GUI apps live in the personal block. */ -}}
{{- if not .headless -}}
{{-   $brews = concat $brews (list
          "borders"
          "dockutil") -}}
{{-   $casks = concat $casks (list
          "aerospace"
          "ghostty"
          "notunes"
          "zed") -}}
{{-   $taps = concat $taps (list
          "FelixKratz/formulae"
          "nikitabobko/tap") -}}
{{- end -}}
{{- /* Headless-only extras: CLI counterparts of GUI tools would go here.
       (tailscale lives in the personal block — it joins the personal tailnet.) */ -}}
{{- if .headless -}}
{{-   $brews = concat $brews (list) -}}
{{-   $casks = concat $casks (list) -}}
{{-   $taps = concat $taps (list) -}}
{{- end -}}

# Ensure brew is on PATH (e.g. immediately after a fresh install in this run,
# before the shell that adds it has been started).
{{ template "brew-shellenv" "brew" }}

# Third-party taps must be tapped and trusted before brew will load their
# casks/formulae (HOMEBREW_REQUIRE_TAP_TRUST). Do this before bundling.
{{ range ($taps | sortAlpha | uniq) -}}
brew tap "{{ . }}"
brew trust "{{ . }}"
{{ end }}
brew bundle --file=/dev/stdin <<EOF
{{ range ($taps | sortAlpha | uniq) -}}
tap "{{ . }}"
{{ end -}}
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF
{{- /* vim: set filetype=bash: */}}
