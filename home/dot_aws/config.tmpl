# AWS CLI configuration. Managed by chezmoi.
#
# SECURITY: this repo is public. NEVER put credentials here. No access keys, no
# ~/.aws/credentials. Identifying values (SSO start URL, account IDs) are pulled
# from the "AWS SSO" item in the Cloudlab 1Password vault at render time
# (onepasswordRead), so only op:// references live in the repo. Region/role/
# profile names aren't secret.
#
# The SSO profiles are generated by ranging over the "accounts" field of that
# item: a JSON array of {name, account_id, role} objects. To add an account,
# append an entry to that JSON in 1Password and re-run `chezmoi apply` — no edit
# to this file is needed. account_id may include dashes; they're stripped below.
#
# Rendered only on the "personal" profile (granted and the Cloudlab vault are
# personal-only); work machines get just the [default] region block — no op read.

[default]
region = {{ .awsRegion }}
output = json
{{ if eq .profile "personal" -}}
{{ $startUrl := onepasswordRead "op://Cloudlab/AWS SSO/start_url" -}}
{{ range (onepasswordRead "op://Cloudlab/AWS SSO/accounts" | fromJson) }}
[profile {{ .name }}]
granted_sso_start_url      = {{ $startUrl }}
granted_sso_region         = us-east-1
granted_sso_account_id     = {{ .account_id | replace "-" "" }}
granted_sso_role_name      = {{ .role }}
common_fate_generated_from = aws-sso
credential_process         = granted credential-process --profile {{ .name }}
{{ end -}}
{{- end -}}
{{- /* vim: set filetype=dosini: */ -}}
