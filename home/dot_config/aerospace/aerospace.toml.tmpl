# AeroSpace - i3-like tiling window manager for macOS. Managed by chezmoi.
# Read from ~/.config/aerospace/aerospace.toml (XDG). Docs:
# https://nikitabobko.github.io/AeroSpace/guide
#
# First run needs Accessibility permission (System Settings > Privacy &
# Security > Accessibility). No SIP changes required (unlike yabai).

# Opt into the config-version 2 schema. Notably this makes `on-window-detected`
# require an explicit `if` filter, and `persistent-workspaces` no longer inferred
# from bindings (defaults to empty). See the migration guide in the docs above.
config-version = 2

# Start tiling automatically at login.
start-at-login = true

# Draw a border around the focused window (JankyBorders), started with AeroSpace.
# Absolute path (AeroSpace's exec environment has a minimal PATH at login),
# resolved to whichever Homebrew prefix exists (Apple Silicon or Intel).
after-startup-command = ['exec-and-forget {{ template "brew-prefix" . }}/bin/borders']

# Keep the window tree tidy (defaults).
enable-normalization-flatten-containers = true
enable-normalization-opposite-orientation-for-nested-containers = true

# Layout defaults.
accordion-padding = 30
default-root-container-layout = 'tiles'
default-root-container-orientation = 'auto'

# Mouse follows focus across monitors (not on every window focus change).
on-focused-monitor-changed = ['move-mouse monitor-lazy-center']

# Leave macOS-hidden apps hidden when focusing.
automatically-unhide-macos-hidden-apps = false

# Re-tile every newly detected window. Apps launched from Finder/Spotlight can
# appear before AeroSpace lays them out (macOS Accessibility timing); forcing a
# tiling pass on detect snaps them into the tree instead of waiting for the next
# focus/workspace event. `if = 'true'` is a catch-all matching every window
# (config-version 2 requires an explicit `if`; omitting it is an error).
[[on-window-detected]]
if = 'true'
run = ['layout tiling']

[key-mapping]
preset = 'qwerty'

# 8px gaps between tiles and screen edges.
[gaps]
inner.horizontal = 8
inner.vertical   = 8
outer.left       = 8
outer.bottom     = 8
outer.top        = 8
outer.right      = 8

[mode.main.binding]
# Layouts: toggle tiling orientation / accordion.
alt-slash = 'layout tiles horizontal vertical'
alt-comma = 'layout accordion horizontal vertical'

# Focus (vim hjkl), wrapping around the workspace at the edges.
alt-h = 'focus --boundaries-action wrap-around-the-workspace left'
alt-j = 'focus --boundaries-action wrap-around-the-workspace down'
alt-k = 'focus --boundaries-action wrap-around-the-workspace up'
alt-l = 'focus --boundaries-action wrap-around-the-workspace right'

# Move the focused window.
alt-shift-h = 'move left'
alt-shift-j = 'move down'
alt-shift-k = 'move up'
alt-shift-l = 'move right'

# Resize the focused window.
alt-minus = 'resize smart -50'
alt-equal = 'resize smart +50'

# Fullscreen and float toggle.
alt-shift-f = 'fullscreen'
alt-shift-space = 'layout floating tiling'

# Switch to workspace 1-9.
alt-1 = 'workspace 1'
alt-2 = 'workspace 2'
alt-3 = 'workspace 3'
alt-4 = 'workspace 4'
alt-5 = 'workspace 5'
alt-6 = 'workspace 6'
alt-7 = 'workspace 7'
alt-8 = 'workspace 8'
alt-9 = 'workspace 9'

# Move the focused window to workspace 1-9.
alt-shift-1 = 'move-node-to-workspace 1'
alt-shift-2 = 'move-node-to-workspace 2'
alt-shift-3 = 'move-node-to-workspace 3'
alt-shift-4 = 'move-node-to-workspace 4'
alt-shift-5 = 'move-node-to-workspace 5'
alt-shift-6 = 'move-node-to-workspace 6'
alt-shift-7 = 'move-node-to-workspace 7'
alt-shift-8 = 'move-node-to-workspace 8'
alt-shift-9 = 'move-node-to-workspace 9'

# Jump back to previous workspace; move current workspace to the next monitor.
alt-tab = 'workspace-back-and-forth'
alt-shift-tab = 'move-workspace-to-monitor --wrap-around next'

# Reload this config after editing.
alt-shift-c = 'reload-config'

# Enter service mode for less-frequent operations (see below).
alt-shift-semicolon = 'mode service'

[mode.service.binding]
esc = ['reload-config', 'mode main']
r = ['flatten-workspace-tree', 'mode main']   # reset layout
f = ['layout floating tiling', 'mode main']   # toggle floating
backspace = ['close-all-windows-but-current', 'mode main']

# Join the focused window into a neighbor (build nested containers).
alt-shift-h = ['join-with left', 'mode main']
alt-shift-j = ['join-with down', 'mode main']
alt-shift-k = ['join-with up', 'mode main']
alt-shift-l = ['join-with right', 'mode main']
