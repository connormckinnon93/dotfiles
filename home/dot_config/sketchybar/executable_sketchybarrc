#!/bin/bash
#
# SketchyBar - macOS status bar. Managed by chezmoi.
# Docs: https://felixkratz.github.io/SketchyBar/
# Colors are fixed catppuccin-mocha hex; SketchyBar can't follow tinty's ANSI
# palette, so this is a deliberate theming exception (like JankyBorders).
#
# Ensure brew bin is reachable (started from AeroSpace/launchd: minimal PATH).
export PATH="/opt/homebrew/bin:$PATH"

PLUGIN_DIR="$CONFIG_DIR/plugins"

# catppuccin mocha
BAR=0xff1e1e2e
FG=0xffcdd6f4
CRUST=0xff11111b
ACCENT=0xffcba6f7
MUTED=0xff6c7086

sketchybar --bar \
  height=32 \
  position=top \
  padding_left=8 \
  padding_right=8 \
  color=$BAR

sketchybar --default \
  icon.font="JetBrainsMono Nerd Font Mono:Bold:14.0" \
  icon.color=$FG \
  label.font="JetBrainsMono Nerd Font Mono:Semibold:13.0" \
  label.color=$FG \
  padding_left=4 \
  padding_right=4 \
  background.height=22 \
  background.corner_radius=6

# --- AeroSpace workspaces (left) ---
sketchybar --add event aerospace_workspace_change

for sid in 1 2 3 4 5 6 7 8 9; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      label="$sid" \
      label.padding_left=7 \
      label.padding_right=7 \
      background.color=$ACCENT \
      background.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# --- Front app (left) ---
sketchybar --add item front_app left \
  --subscribe front_app front_app_switched \
  --set front_app \
    icon.drawing=off \
    label.font="JetBrainsMono Nerd Font Mono:Bold:13.0" \
    label.padding_left=12 \
    script="$PLUGIN_DIR/front_app.sh"

# --- Right side: clock, battery, wifi ---
sketchybar --add item clock right \
  --set clock icon="" update_freq=10 script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --subscribe battery system_woke power_source_change \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh"

sketchybar --add item wifi right \
  --subscribe wifi wifi_change \
  --set wifi icon="" update_freq=30 script="$PLUGIN_DIR/wifi.sh"

# Render everything, then set the initial focused-workspace highlight.
sketchybar --update
sketchybar --trigger aerospace_workspace_change \
  FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused 2>/dev/null)"
