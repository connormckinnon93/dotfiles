// zellij theme that follows the terminal's ANSI palette (driven by tinty), so
// `tinty apply <scheme>` recolors zellij like the rest of the stack. The single
// integers are 8-bit color indices; 0-15 map to the terminal's ANSI palette.
themes {
    tinty {
        fg 7
        bg 0
        black 0
        red 1
        green 2
        yellow 3
        blue 4
        magenta 5
        cyan 6
        white 7
        orange 3
    }
}
