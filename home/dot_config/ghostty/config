# Font
# Mono variant = single-width glyphs (best for terminals). Installed via
# chezmoiexternal; see .chezmoiexternal.toml.tmpl.
font-family = "JetBrainsMono Nerd Font Mono"

# Colors
# No static theme on purpose: tinty/tinted-shell sets the ANSI palette plus
# foreground/background/cursor (OSC 10/11/12) at shell startup, so the terminal
# follows `tinty apply <scheme>` and stays consistent with the rest of the stack.

# Window
confirm-close-surface = false
# No window decorations: strips the titlebar and (enforced by macOS) disables
# native tabs, which fight AeroSpace's tiling - each native tab is a separate
# NSWindow, so clicking a tab made AeroSpace re-layout. Use AeroSpace windows
# or a multiplexer (zellij) for "tabs" instead.
window-decoration = none

# Cursor
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# Shell integration
# ssh-env/ssh-terminfo propagate Ghostty's terminfo to remote hosts so colors
# and keys work over SSH (otherwise TERM=xterm-ghostty is unknown remotely).
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo

# Clipboard
clipboard-read = allow
clipboard-write = allow

# macOS
macos-option-as-alt = true

# Keybindings
keybind = global:cmd+backquote=toggle_quick_terminal
# Make the tab muscle-memory create a (tileable) window instead of a native tab.
keybind = cmd+t=new_window
