# Homebrew environment (read automatically from ~/.config/homebrew/brew.env).
HOMEBREW_BAT=1
HOMEBREW_NO_ANALYTICS=1
HOMEBREW_NO_ENV_HINTS=1
# Auto-update the formulae DB at most weekly (168h), matching the antidote
# git-repo refreshPeriod in .chezmoiexternal.toml.tmpl — the other external that
# tracks a moving upstream. 168h * 3600 = 604800s. (Was NO_AUTO_UPDATE=1, i.e.
# never auto-updating; manual `brew update` still works any time.)
HOMEBREW_AUTO_UPDATE_SECS=604800
# Require third-party taps to be explicitly `brew trust`ed before their
# formulae/casks load (see install-packages script's tap/trust loop).
HOMEBREW_REQUIRE_TAP_TRUST=1
