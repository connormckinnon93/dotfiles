{{- /*
  Resolves chezmoi's os/arch onto the matching Rust release target triple.
  Linux uses the statically-linked musl variant, which most prebuilt release
  binaries ship and which avoids glibc version mismatches.
  Usage: {{ includeTemplate "rust-target" . }}
*/ -}}
{{- $targets := dict
      "darwin-amd64" "x86_64-apple-darwin"
      "darwin-arm64" "aarch64-apple-darwin"
      "linux-amd64"  "x86_64-unknown-linux-musl"
      "linux-arm64"  "aarch64-unknown-linux-musl"
   -}}
{{- index $targets (printf "%s-%s" .chezmoi.os .chezmoi.arch) -}}
